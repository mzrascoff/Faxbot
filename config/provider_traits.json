  "phaxio": {
    "id": "phaxio",
    "kind": "cloud",
    "traits": {
      "requires_ghostscript": true,
      "requires_ami": false,
      "requires_tiff": false,
      "supports_inbound": true,
      "inbound_verification": "hmac",
      "needs_storage": true,
      "outbound_status_only": false,
      "supports_status_callback": true,
      "webhook_path": "/phaxio-callback",
      "verify_header": "X-Phaxio-Signature",
      "webhook.verification": "hmac_sha256",
      "webhook.path": "/phaxio-callback",
      "webhook.verify_header": "X-Phaxio-Signature",
      "auth.methods": ["basic"],
      "sample_payload": {
        "fax": { "id": 12345, "num_pages": 3, "status": "success" }
      }
    }
  },
