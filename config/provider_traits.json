      "webhook.verification": "basic_auth",
      "webhook.path": "/sinch-inbound",
      "webhook.verify_header": "Authorization",
      "auth.methods": ["basic", "oauth2"],
      "env.fallback": "SINCH_*=PHAXIO_*",
